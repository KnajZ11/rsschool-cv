{
  "compilerOptions": {
    "target": "ES6",
    "module": "ES6",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": false,
    "lib": ["DOM", "ES2017"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}